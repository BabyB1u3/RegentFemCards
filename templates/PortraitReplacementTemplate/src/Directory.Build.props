<Project>
    <PropertyGroup>
        <!-- The generator normally passes GodotPath explicitly during build. -->
        <!-- Keep a development fallback so the template can still be built by hand on a dev machine. -->
        <GodotPath Condition="'$(GodotPath)' == '' and Exists('C:/megadot/MegaDot_v4.5.1-stable_mono_win64.exe')">C:/megadot/MegaDot_v4.5.1-stable_mono_win64.exe</GodotPath>

        <!-- If sts2 is not found automatically, uncomment the following and set it manually -->
        <!-- <Sts2Path>?/steamapps/common/Slay the Spire 2</Sts2Path> -->
    </PropertyGroup>
</Project>
